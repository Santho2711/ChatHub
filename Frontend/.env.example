# Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
REACT_APP_API_URL=http://localhost:5000
REACT_APP_WS_URL=ws://localhost:5000

# Authentication
REACT_APP_AUTH_PROVIDER=local
# REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
# REACT_APP_FIREBASE_PROJECT_ID=your_firebase_project_id

# Feature Flags
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_EMOJI_PICKER=true
REACT_APP_ENABLE_GROUP_CHAT=true
REACT_APP_ENABLE_THEMES=true

# App Configuration
REACT_APP_MAX_MESSAGE_LENGTH=4096
REACT_APP_MAX_GROUP_MEMBERS=500
REACT_APP_MESSAGE_HISTORY_LIMIT=100

# Debug Mode
REACT_APP_DEBUG=false
REACT_APP_LOG_LEVEL=info
